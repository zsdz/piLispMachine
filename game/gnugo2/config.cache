# This file is a shell script that caches the results of configure
# tests run on this system so they can be shared between configure
# scripts and configure runs.  It is not useful on other systems.
# If it contains results you don't want to keep, you may remove or edit it.
#
# By default, configure uses ./config.cache as the cache file,
# creating it if it does not exist already.  You can give configure
# the --cache-file=FILE option to use a different cache file; that is
# what configure does when it calls configure scripts in
# subdirectories, so they share the cache.
# Giving --cache-file=/dev/null disables caching, for debugging configure.
# config.status only pays attention to the cache file if you give it the
# --recheck option to rerun configure.
#
ac_cv_c_const=${ac_cv_c_const='yes'}
ac_cv_cygwin=${ac_cv_cygwin='no'}
ac_cv_exeext=${ac_cv_exeext='no'}
ac_cv_func_alarm=${ac_cv_func_alarm='yes'}
ac_cv_func_gettimeofday=${ac_cv_func_gettimeofday='yes'}
ac_cv_func_random=${ac_cv_func_random='yes'}
ac_cv_func_setlinebuf=${ac_cv_func_setlinebuf='yes'}
ac_cv_func_snprintf=${ac_cv_func_snprintf='yes'}
ac_cv_header_curses_h=${ac_cv_header_curses_h='yes'}
ac_cv_header_string_h=${ac_cv_header_string_h='yes'}
ac_cv_header_sys_mkdev_h=${ac_cv_header_sys_mkdev_h='no'}
ac_cv_header_sys_sysmacros_h=${ac_cv_header_sys_sysmacros_h='yes'}
ac_cv_header_sys_time_h=${ac_cv_header_sys_time_h='yes'}
ac_cv_header_sys_types_h_makedev=${ac_cv_header_sys_types_h_makedev='no'}
ac_cv_header_term_h=${ac_cv_header_term_h='yes'}
ac_cv_header_unistd_h=${ac_cv_header_unistd_h='yes'}
ac_cv_lib_ncurses_tputs=${ac_cv_lib_ncurses_tputs='yes'}
ac_cv_mingw32=${ac_cv_mingw32='no'}
ac_cv_path_install=${ac_cv_path_install='/usr/bin/install -c'}
ac_cv_prog_CC=${ac_cv_prog_CC='gcc'}
ac_cv_prog_CPP=${ac_cv_prog_CPP='gcc -E'}
ac_cv_prog_RANLIB=${ac_cv_prog_RANLIB='ranlib'}
ac_cv_prog_cc_cross=${ac_cv_prog_cc_cross='no'}
ac_cv_prog_cc_g=${ac_cv_prog_cc_g='yes'}
ac_cv_prog_cc_works=${ac_cv_prog_cc_works='yes'}
ac_cv_prog_gcc=${ac_cv_prog_gcc='yes'}
ac_cv_prog_gcc_traditional=${ac_cv_prog_gcc_traditional='no'}
ac_cv_prog_make_make_set=${ac_cv_prog_make_make_set='yes'}
